# Portable application home. By default this is <HaizFlow install>\runtime,
# so selecting another drive in the installer keeps all app-owned files there.
# Use this override for development or portable deployments:
# HAIZFLOW_HOME=D:\HaizFlowData
# RUNTIME_DATA_DIR defaults to HAIZFLOW_HOME\data; override only for migration.
# RUNTIME_DATA_DIR=D:\HaizFlowData

# Whisper transcription
# Models: tiny, base, small, medium, large-v3
WHISPER_MODEL=small

# HY-MT2 local machine translation. The model downloads into HF_HOME on first use.
HYMT2_MODEL=tencent/Hy-MT2-1.8B

# Edge TTS requests are sent concurrently. Keep this between 1 and 4.
TTS_MAX_CONCURRENCY=1

# Without HAIZFLOW_HOME, advanced deployments may override individual caches.
# When HAIZFLOW_HOME is set, it is a hard boundary and these are ignored so a
# machine-wide environment variable cannot silently redirect files to drive C.
# HF_HOME=D:\HaizFlowData\cache\huggingface
# TORCH_HOME=D:\HaizFlowData\cache\torch
# PIP_CACHE_DIR=D:\HaizFlowData\cache\pip
# UV_CACHE_DIR=D:\HaizFlowData\cache\uv
# HAIZFLOW_TMP_DIR=D:\HaizFlowData\cache\tmp
